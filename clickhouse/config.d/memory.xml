<?xml version="1.0"?>
<!--
  Bound ClickHouse memory and reconcile its MemoryTracking counter.

  Context: this server is a 3.8 GiB Azure VM shared with backend / indexer /
  translator / notifier / frontend / traefik / clickhouse-container itself.
  The 24.12 image defaults max_server_memory_usage_to_ram_ratio to 0.9, so CH
  reserves ~3.39 GiB for itself — leaving ~400 MiB for everything else.

  And the memory worker that reconciles the in-process MemoryTracking counter
  against jemalloc's real allocator state is OFF by default in 24.12
  (memory_worker_period_ms = 0). Without it, every cancelled query / killed
  mutation / failed insert can leak a few "ghost" bytes into the counter that
  jemalloc has long since freed. Those leaks accumulate until MemoryTracking
  hits the limit and CH starts rejecting every new query with
  MEMORY_LIMIT_EXCEEDED — even though the actual RSS is a fraction of the
  limit. Restarting CH is the only way to clear the stuck counter; we've
  already had to do that once today.

  Fix:
    * Re-cap CH at 70% of host RAM (~2.65 GiB) so it doesn't starve the
      other containers.
    * Re-cap merges/mutations at 35% so a runaway merge can't squeeze out
      online queries.
    * Run the memory worker every second AND let it correct MemoryTracking
      against jemalloc — counter drift is bounded to ~1s of activity instead
      of accumulating indefinitely.
-->
<clickhouse>
    <max_server_memory_usage_to_ram_ratio>0.7</max_server_memory_usage_to_ram_ratio>
    <merges_mutations_memory_usage_to_ram_ratio>0.35</merges_mutations_memory_usage_to_ram_ratio>
    <memory_worker_period_ms>1000</memory_worker_period_ms>
    <memory_worker_correct_memory_tracker>1</memory_worker_correct_memory_tracker>
</clickhouse>
