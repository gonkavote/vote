# ============================================================================
# Vote portal — config
#
# Copy to `.env` and fill in. NEVER commit `.env`.
#   cp .env.template .env  &&  $EDITOR .env
#
# Every value here corresponds to one of two things:
#   1. A required deployment identity (your domain, your chain, your tracker)
#   2. A secret (oauth, session, bot tokens) — never commit these.
# ============================================================================


# ----------------------------------------------------------------------------
# Public site
# ----------------------------------------------------------------------------
# The hostname Traefik matches on. Use `localhost` for dev.
PUBLIC_HOST=your-domain.example
# Public base URL of the deployment (no trailing slash). Used for OAuth
# redirects, Telegram webhook registration, SSR canonical/OG URLs, sitemap.
PUBLIC_BASE_URL=https://your-domain.example
# CORS allow-list — JSON-encoded array. For prod usually one item equal to PUBLIC_BASE_URL.
CORS_ORIGINS=["https://your-domain.example"]
# Cookie security. True in prod (HTTPS). Set false only on plain-HTTP localhost.
COOKIE_SECURE=true
# Optional — leave commented unless serving subdomains. Otherwise omit.
# COOKIE_DOMAIN=your-domain.example


# ----------------------------------------------------------------------------
# Gonka chain — REQUIRED
# Point at any reachable Gonka full node (HTTP-only is fine; the backend
# proxies the chain REST over the same origin to avoid mixed-content blocks).
# ----------------------------------------------------------------------------
CHAIN_ID=gonka-mainnet
# Indexer-facing pair. The Go indexer needs tx_indexer=on AND non-pruned
# /cosmos/bank/balances on the same node. Most public RPCs work; if
# /tx_search returns "transaction indexing is disabled", switch nodes.
RPC_URL=http://your-node.example:8000/chain-rpc
CHAIN_API_URL=http://your-node.example:8000/chain-api
# Backend-facing pair (OPTIONAL). Use these when the broadcast/proxy
# node should differ from the indexer node — e.g. the indexer node is
# slow on /tx_search but a different node is faster for broadcasts.
# Leave empty to reuse RPC_URL / CHAIN_API_URL above.
# BACKEND_RPC_URL=
# BACKEND_CHAIN_API_URL=
# Wasm voting contract address (filled in after `contract/scripts/deploy.sh`).
CONTRACT_ADDRESS=gonka1...
# Indexer polling cadence.
SCAN_INTERVAL=15s
SNAPSHOT_INTERVAL=60s
BALANCE_CONCURRENCY=10


# ----------------------------------------------------------------------------
# Tracker (read-only governance mirror) — REQUIRED
# ----------------------------------------------------------------------------
# Backend → tracker REST API base, used to fan out governance polls.
TRACKER_API_URL=http://your-tracker.example/api/v1
# Tracker UI base. Frontend renders explorer links (address/tx) against
# this when non-empty; empty disables those out-links cleanly.
TRACKER_UI_URL=https://your-tracker.example


# ----------------------------------------------------------------------------
# ClickHouse
# ----------------------------------------------------------------------------
CLICKHOUSE_DB=gonka_vote
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=


# ----------------------------------------------------------------------------
# WalletConnect (Reown) — get a projectId at https://cloud.reown.com/
# Leave empty to disable the in-app wallet flow (CLI vote still works).
# ----------------------------------------------------------------------------
WC_PROJECT_ID=


# ----------------------------------------------------------------------------
# Google OAuth (optional — leave empty to disable Google sign-in).
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be: ${PUBLIC_BASE_URL}/api/auth/callback
# ----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ----------------------------------------------------------------------------
# Telegram (optional — leave empty to disable Telegram sign-in & notifications).
#   1. /newbot in @BotFather → grab the bot token
#   2. /setdomain → ${PUBLIC_HOST}
# ----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
# Shared secret passed to Telegram via setWebhook; Telegram echoes it in
# X-Telegram-Bot-Api-Secret-Token on every update. Leave empty to disable
# the webhook handler (then /stop in the bot becomes a no-op). Generate
# with: `openssl rand -hex 32`
TELEGRAM_WEBHOOK_SECRET=


# ----------------------------------------------------------------------------
# Secrets — REQUIRED
# ----------------------------------------------------------------------------
# Signs the session cookie. Rotating invalidates all sessions.
# Generate with: `openssl rand -hex 32`
SESSION_SECRET=


# ----------------------------------------------------------------------------
# Translation worker (Gemini) — optional.
# Comma-separated list of language codes the SPA supports. Each new code
# means one more frontend dictionary file and one re-translation pass for
# every proposal/comment.
# ----------------------------------------------------------------------------
TRANSLATION_LANGUAGES=en,ru
# Up to 3 Gemini API keys for translation worker fallback. Get keys at
# https://aistudio.google.com/app/apikey. Leave empty to disable translations.
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=


# ----------------------------------------------------------------------------
# Advanced tuning (OPTIONAL — every var below has a sane default in compose;
# uncomment only when you actually need to change it).
# ----------------------------------------------------------------------------
# Indexer's HTTP timeout for chain RPC/REST calls.
# HTTP_TIMEOUT=30s
# How often the backend pulls active governance proposals from tracker.
# GOVERNANCE_POLL_INTERVAL=60
# Freshness thresholds (seconds) for the on-demand governance list/detail
# refreshes. Higher = fewer tracker calls, more potentially-stale UI rows.
# GOVERNANCE_LIST_TTL=300
# GOVERNANCE_DETAIL_TTL=60
# Translator queue tuning.
# TRANSLATION_POLL_INTERVAL=5
# TRANSLATION_MAX_ATTEMPTS=5
# Notifier queue tuning.
# NOTIFICATION_POLL_INTERVAL=5
# NOTIFICATION_MAX_ATTEMPTS=3
# NOTIFICATION_RETRY_DELAY_SEC=60


# ----------------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------------
LOG_LEVEL=INFO
